# Copy to .env.docker and run:
# docker compose --env-file .env.docker up --build -d

SWUFE_RAG_PORT=8000
SWUFE_RAG_WORKERS=1
SWUFE_RAG_REQUIRE_REDIS=1
SWUFE_RAG_EAGER_WARMUP=0
SWUFE_RAG_TRUST_PROXY=0
SWUFE_RAG_ALLOW_MODEL_DOWNLOAD=1
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
HF_CACHE_DIR=~/.cache/huggingface
SWUFE_RAG_CACHE_VERSION=docker-dev-v2
SWUFE_RAG_ALLOW_FAKE_DNS=1
SWUFE_RAG_LLM_ALLOWED_HOSTS=llm-g7aepc8gwf4oz35h.cn-beijing.maas.aliyuncs.com

SWUFE_RAG_QUERY_MAX_CONCURRENCY=4
SWUFE_RAG_QUERY_QUEUE_SIZE=16
SWUFE_RAG_QUERY_QUEUE_TIMEOUT=8
SWUFE_REDIS_MAXMEMORY=512mb

# Optional server-side model. Leave the key blank when the iOS app supplies a
# provider key through its BYOK model settings.
SWUFE_RAG_LLM_API_KEY=
SWUFE_RAG_LLM_BASE_URL=https://api.deepseek.com
SWUFE_RAG_LLM_MODEL=deepseek-chat
