# DeepSeek / other OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
# Comma-separated exact hostnames added to the built-in BYOK provider allowlist.
SWUFE_RAG_LLM_ALLOWED_HOSTS=
SWUFE_RAG_ALLOW_FAKE_DNS=0

# Ollama normally accepts a placeholder key.
OLLAMA_API_KEY=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# Retrieval admission and local same-key result cache
SWUFE_RAG_QUERY_MAX_CONCURRENCY=2
SWUFE_RAG_QUERY_QUEUE_SIZE=8
SWUFE_RAG_QUERY_QUEUE_TIMEOUT=8
SWUFE_RAG_CACHE_VERSION=dev-v1
SWUFE_RAG_RETRIEVAL_CACHE_SIZE=512
SWUFE_RAG_RETRIEVAL_CACHE_TTL=300

# Multi-worker deployments require shared sessions and distributed locks.
# This is also enabled automatically whenever SWUFE_RAG_WORKERS is greater than 1.
SWUFE_RAG_REQUIRE_REDIS=0
