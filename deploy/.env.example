# 部署配置样例。复制为项目根目录的 .env(Docker Compose)
# 或 /etc/swufe-rag.env(systemd),然后按实际情况修改。
#
# ⚠️ 不要把 LLM API Key 写进这里。客户端按次通过 X-LLM-API-Key 请求头
#    自带 Key(BYOK),服务端不持有、不记录任何用户 Key。

# 客户端自定义 OpenAI-compatible 地址仅允许 HTTPS 和内置厂商域名。
# 需要额外厂商时填写精确域名(逗号分隔);解析到私网/回环/元数据 IP 仍会拒绝。
SWUFE_RAG_LLM_ALLOWED_HOSTS=

# --- 进程与并发 ---
# 每个 worker 独立加载模型+索引,实测常驻约 1.0GB。
# 8G 内存机器建议 2,16G 建议 4。
SWUFE_RAG_WORKERS=2

# 检索并发闸门。云服务器纯 CPU,BGE 编码比本机 MPS 慢 3~10 倍,
# 上线后按 /readyz 里的 query_capacity 统计(queue_waits/timed_out)调整。
SWUFE_RAG_QUERY_MAX_CONCURRENCY=4
SWUFE_RAG_QUERY_QUEUE_SIZE=16
SWUFE_RAG_QUERY_QUEUE_TIMEOUT=8

# 每 worker 的 CPU 线程数,避免多 worker 争抢。
# 经验值:总核数 / workers 数。
OMP_NUM_THREADS=2

# --- 限流(公网必开)---
# 每个 IP 每 SWUFE_RAG_RATE_WINDOW 秒最多多少次请求;0 表示关闭。
# 30/60s 对正常用户绰绰有余(人均问一题要十几秒)。
SWUFE_RAG_RATE_LIMIT=30
SWUFE_RAG_RATE_WINDOW=60
# 仅在 Nginx 等反代后面设为 1。直接暴露时务必保持 0,
# 否则客户端可以伪造 X-Forwarded-For 绕过限流。
SWUFE_RAG_TRUST_PROXY=1
SWUFE_RAG_FORWARDED_ALLOW_IPS=*

# --- Redis(会话外置 / 答案缓存 / 限流计数)---
# Compose 内部用服务名;systemd 部署改为 redis://127.0.0.1:6379/0
SWUFE_RAG_REDIS_URL=redis://redis:6379/0
# 多 worker 必须为 1；即使误设为 0，workers>1 仍会自动强制 Redis。
SWUFE_RAG_REQUIRE_REDIS=1
SWUFE_RAG_SESSION_TTL=259200        # 会话记忆保留 3 天
SWUFE_RAG_ANSWER_CACHE_TTL=86400    # 答案缓存 1 天
REDIS_MAXMEMORY=512mb

# --- 启动行为 ---
# 1 = 启动即后台预热模型,加载完成前 /readyz 返回 503,
#     负载均衡器不会把请求打到冷实例上(生产建议开启)。
SWUFE_RAG_EAGER_WARMUP=1

# --- 模型缓存位置(宿主机)---
# 容器只读挂载这个目录,内部不联网下载。
HF_CACHE_DIR=~/.cache/huggingface

# --- 数据路径(一般不用改,除非数据不在默认位置)---
# SWUFE_RAG_CHUNKS=data/chunks.jsonl
# SWUFE_RAG_METADATA=data/metadata.sqlite3
# SWUFE_RAG_ACADEMIC_DB=data/academic_v2.sqlite3
# SWUFE_RAG_ARTIFACTS=artifacts
